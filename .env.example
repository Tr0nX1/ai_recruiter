# Copy to .env and fill in values. Never commit real secrets.
# Primary LLM — required
ANTHROPIC_API_KEY=
# Optional — only needed for OpenAI embeddings in crew memory
OPENAI_API_KEY=
APIFY_API_TOKEN=
GOOGLE_CREDENTIALS_FILE=credentials.json
GDRIVE_FOLDER_ID=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# LLM overrides (defaults: Anthropic Claude models)
FAST_LLM=anthropic/claude-3-5-haiku-20241022
SMART_LLM=anthropic/claude-sonnet-4-20250514

# Crew memory (uses HuggingFace embeddings when true)
USE_CREW_MEMORY=false

# Phase 3 — API retries (transient rate limits / timeouts)
API_RETRY_MAX_ATTEMPTS=3
API_RETRY_MIN_WAIT_SEC=4
API_RETRY_MAX_WAIT_SEC=60

# Phase 4 — Google Drive (service account JSON with Drive read-only; share folder with SA email)
GDRIVE_FOLDER_ID=
GDRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=outputs/gdrive_token.json
GDRIVE_WATCH_INTERVAL_SECONDS=60

# Dedupe & memory
SKIP_DUPLICATE_RESUMES=true
DUPLICATE_HASH_MODE=bytes
ENABLE_EVALUATION_MEMORY=true

# Apify LinkedIn (optional)
APIFY_ACTOR_ID=bebity/linkedin-premium-actor
