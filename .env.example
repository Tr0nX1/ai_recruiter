# Copy to .env and fill in values. Never commit real secrets.
# Primary LLM — required
OPENROUTER_API_KEY=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

# Optional — only needed for specific OpenAI functions outside of primary OpenRouter pipeline
# OPENAI_API_KEY=

# LLM overrides (Standard OpenRouter Models)
FAST_LLM=openrouter/meta-llama/llama-3.1-8b-instruct
FAST_FALLBACK_LLM=openrouter/mistral/mistral-7b-instruct
SMART_LLM=openrouter/openai/gpt-4o-mini
SMART_FALLBACK_LLM=openrouter/google/gemini-flash-1.5

# Crew memory (uses HuggingFace embeddings when true)
USE_CREW_MEMORY=false

# Phase 3 — API retries (transient rate limits / timeouts)
API_RETRY_MAX_ATTEMPTS=3
API_RETRY_MIN_WAIT_SEC=4
API_RETRY_MAX_WAIT_SEC=60

# Dedupe & memory
SKIP_DUPLICATE_RESUMES=true
DUPLICATE_HASH_MODE=bytes
ENABLE_EVALUATION_MEMORY=true
